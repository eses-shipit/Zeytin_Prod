# Bu dosya şablondur ve git'e girer. Gerçek değerleri .env içine yazın; .env
# ve .env.* git tarafından yok sayılır.

# PostgreSQL bağlantı adresi
DATABASE_URL="postgresql://user:password@localhost:5432/zeytin"

# JWT imzalama anahtarı. Boot sırasında ZORUNLUDUR: tanımsızsa veya 32
# karakterden kısaysa uygulama başlamaz.
# Üretmek için: openssl rand -base64 48
JWT_SECRET=""

# API portu
PORT=3001

# İzin verilen frontend adresi (CORS)
FRONTEND_URL="http://localhost:3000"

# development | test | production
NODE_ENV="development"

# İlk platform sahibini oluşturmak için: npm run seed:super-admin
SUPER_ADMIN_EMAIL=""
SUPER_ADMIN_PASSWORD=""
