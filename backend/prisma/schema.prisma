generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TenantStatus {
  ACTIVE
  SUSPENDED
}

model Tenant {
  id                  String            @id @default(cuid())
  name                String
  officialName        String? // Resmi Unvan
  taxId               String? // Vergi No
  address             String?
  city                String?
  code                String?           @unique // Örn: 'AYD' - Fabrika kısa kodu
  status              TenantStatus      @default(ACTIVE)
  subscriptionEndDate DateTime?
  defaultDrumWeight   Decimal           @default(50) @db.Decimal(8, 3) // Varsayılan bidon ağırlığı (kg)
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  users               User[]
  licenses            License[]
  tickets             SupportTicket[]
  // Relations for Tenant Data Isolation
  products            Product[]
  customers           Customer[]
  weighingTickets     WeighingTicket[]
  productionBatches   ProductionBatch[]
  stockTanks          StockTank[]
  transactions        Transaction[]
  auditLogs           AuditLog[]
  drums               Drum[]
  policies            TenantPolicy[]
  drumSizes           DrumSize[]
  dailyOilPrices      DailyOilPrice[]
}

// ... existing enums and models ...

enum TicketPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum SupportTicketStatus {
  OPEN
  IN_PROGRESS
  WAITING_FOR_CUSTOMER
  RESOLVED
}

enum DrumType {
  PLASTIC
  CHROME
  TIN
}

enum DrumStatus {
  AVAILABLE
  FILLED
  WITH_CUSTOMER
}

enum ProductionStatus {
  PROCESSING
  COMPLETED
  DELIVERED
}

model SupportTicket {
  id         String              @id @default(cuid())
  tenantId   String
  subject    String
  priority   TicketPriority      @default(NORMAL)
  status     SupportTicketStatus @default(OPEN)
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt
  resolvedAt DateTime?

  tenant   Tenant          @relation(fields: [tenantId], references: [id])
  messages TicketMessage[]
}

model TicketMessage {
  id        String   @id @default(cuid())
  ticketId  String
  message   String
  sender    String // 'ADMIN' or 'CUSTOMER'
  createdAt DateTime @default(now())

  ticket SupportTicket @relation(fields: [ticketId], references: [id])
}

model AuditLog {
  id         String   @id @default(cuid())
  tenantId   String
  userId     String?
  action     String // 'DELETE_BATCH', 'LOGIN', etc.
  resourceId String? // ID of the affected resource
  details    Json? // Stores old/new values
  ipAddress  String?
  createdAt  DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  USER
}

enum LeadStatus {
  NEW
  CONTACTED
  CONVERTED
  REJECTED
}

/// Landing page'deki "lisans al / demo iste" formundan gelen talepler.
///
/// Bu bir tenant modeli DEĞİL: kayıt öncesi, henüz fabrikası olmayan
/// ziyaretçilerden gelir. tenantId taşımaz, bu yüzden fail-closed Prisma
/// katmanı onu kapsamaz (bkz. prisma.service UNSCOPED mantığı — tenantId
/// alanı olmayan modeller zaten kapsanmıyor).
///
/// E-posta gönderimi için harici bir servis (SMTP/Resend) kurulu olmadığından
/// talepler burada saklanır ve süper admin panelinden görülür. Servis
/// eklenince bildirim buradan tetiklenebilir.
model Lead {
  id          String     @id @default(cuid())
  name        String
  email       String
  phone       String?
  factoryName String?
  city        String?
  message     String?
  /// Talebin geldiği plan (STANDARD / PRO / DEMO) — pazarlama takibi için.
  interest    String?
  /// Formu hangi dilde doldurdu (tr/es/it/pt).
  locale      String     @default("tr")
  status      LeadStatus @default(NEW)
  note        String? // Süper admin'in iç notu
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([status, createdAt])
}

model User {
  id              String    @id @default(cuid())
  email           String    @unique
  password        String
  name            String?
  phone           String? // Yetkili Telefon
  role            UserRole  @default(USER)
  tenantId        String?
  acceptedTermsAt DateTime? // KVKK ve Kullanım Koşulları onay tarihi
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  tenant       Tenant?              @relation(fields: [tenantId], references: [id])
  resetTokens  PasswordResetToken[]
}

/// Parola sıfırlama token'ı.
///
/// Ham token DEĞİL, SHA-256 özeti saklanır: veritabanı sızsa bile token'lar
/// kullanılamaz. Tek kullanımlık (usedAt) ve kısa ömürlü (expiresAt).
model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
}

/// E-posta OTP doğrulaması (kayıt + iletişim formu).
///
/// Ham 6 haneli kod DEĞİL, bcrypt özeti saklanır: DB sızsa bile kodlar
/// kullanılamaz. Kısa ömürlü (expiresAt), tek kullanımlık (consumedAt) ve
/// deneme sınırlı (attempts). `tenantId` YOK — hesap öncesi/herkese açık akış
/// olduğundan fail-closed tenant katmanı bu modele dokunmaz (Lead gibi).
///
/// `purpose`: "REGISTER" | "CONTACT". Bir amaçtan doğrulanan e-posta, kısa bir
/// güven penceresinde diğer amaç için de doğrulanmış sayılır (bkz. servis) —
/// böylece iletişim formunda onaylanan kullanıcı kayıtta tekrar OTP girmez.
model EmailOtp {
  id         String    @id @default(cuid())
  email      String
  codeHash   String
  purpose    String
  expiresAt  DateTime
  consumedAt DateTime?
  attempts   Int       @default(0)
  createdAt  DateTime  @default(now())

  @@index([email, consumedAt])
  @@index([email, purpose, createdAt])
}

enum LicenseStatus {
  UNUSED
  USED
}

model License {
  id               String        @id @default(cuid())
  code             String        @unique // Örn: 'ZEYTIN-2026-IZMIR01'
  status           LicenseStatus @default(UNUSED)
  planDurationDays Int           @default(365)
  tenantId         String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  tenant Tenant? @relation(fields: [tenantId], references: [id])
}

model Product {
  id        String   @id @default(cuid())
  name      String
  isActive  Boolean  @default(true)
  tenantId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant  Tenant?          @relation(fields: [tenantId], references: [id])
  tickets WeighingTicket[]

  @@unique([name, tenantId]) // Her fabrika aynı isimde ürün ekleyebilir
}

model Customer {
  id              String   @id @default(cuid())
  name            String
  phone           String?
  tckn            String?
  village         String?
  // Para ve yağ alanları Decimal'dir. Float (double precision) ikili kayan
  // nokta hatası biriktirir: bakiyeler sürekli artırılıp azaltıldığı için
  // hata kalıcıdır ve müstahsil makbuzu ile veritabanı zamanla ayrışır.
  oliveOilBalance Decimal  @default(0) @db.Decimal(12, 3) // Kg cinsinden yağ bakiyesi
  balanceTL       Decimal  @default(0) @db.Decimal(14, 2) // TL cinsinden borç/alacak
  tenantId        String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant       Tenant?          @relation(fields: [tenantId], references: [id])
  tickets      WeighingTicket[]
  transactions Transaction[]
  drums        Drum[]           @relation("DrumHolder")
}

enum TicketStatus {
  PENDING
  COMPLETED
}

enum OliveQuality {
  TREE // Üst/Sırık
  GROUND // Dip
  MIXED // Karışık
}

model WeighingTicket {
  id            String  @id @default(cuid())
  publicId      String? // Hibrit ID: 26-0042-X7K (Unique per tenant removed from here, handled in app logic or composite unique)
  customerId    String
  grossKg       Int
  tareKg        Int
  netKg         Int
  scaleWeightKg Int?

  // Master Data
  origin       String? // Köy/Mevkii
  variety      String? // Deprecated: Product modeline geçildi, eski kayıtlar için kalsın
  productId    String? // Yeni ilişki
  quality      OliveQuality? // Kalite
  containerNos String? // Bidon numaraları
  note         String? // Yeni Alan: Not

  status    TicketStatus @default(PENDING)
  batchId   String?
  tenantId  String?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  tenant   Tenant?          @relation(fields: [tenantId], references: [id])
  customer Customer         @relation(fields: [customerId], references: [id])
  product  Product?         @relation(fields: [productId], references: [id])
  batch    ProductionBatch? @relation(fields: [batchId], references: [id])

  @@unique([publicId, tenantId]) // PublicID fabrika bazında unique olmalı
}

enum ServiceType {
  PERCENTAGE // Yağdan Pay
  CASH_PER_KG // Para (Kg başı)
}

/// Yüzde modelinde hak yağın matrahı.
enum FeeBasis {
  OIL_OUT // Çıkan yağın yüzdesi (yaygın: randıman riski paylaşılır)
  OLIVE_IN // Giren zeytinin yüzdesi (randıman riski müstahsilde)
}

/// Bozdurma biriminin fiyatı nereden gelir?
enum PriceSource {
  PER_TRANSACTION // Operatör her işlemde yazar (mevcut davranış)
  DAILY_TABLE // Fabrikanın o gün için tanımladığı fiyat zorunlu
}

/// Emanetteki yağın nasıl takip edildiği.
enum EscrowModel {
  FUNGIBLE // Tankta havuzlanır; müşteri "X kg yağ" alacaklısıdır
  LOT_TRACKED // Müşterinin partisi ayrı tutulur, kendi yağını geri alır
}

/// Fabrikanın çalışma kuralları. SÜRÜMLENİR — güncellenmez.
///
/// Bir kural değiştiğinde satır güncellenmez, yeni bir sürüm yazılır ve eski
/// sürüm olduğu gibi kalır. ProductionBatch, hesaplandığı sürüme (policyId) bağlanır.
///
/// Neden: fabrika hak yağ oranını sezon ortasında %10'dan %12'ye çıkardığında,
/// geçen ayki partilerin makbuzu değişmemelidir. Kural tek satırda tutulup
/// güncellenseydi, eski bir makbuzu yeniden hesaplayan her rapor (ve her
/// anlaşmazlıkta müstahsile gösterilen belge) yanlış sonuç verirdi. Bu bir
/// muhasebe/ispat gereğidir, konfor değil.
model TenantPolicy {
  id            String   @id @default(cuid())
  tenantId      String
  version       Int // Fabrika içinde artan
  effectiveFrom DateTime @default(now())
  /// Yeni parti hesaplarında kullanılan sürüm. Fabrika başına tek bir aktif
  /// sürüm olur; eskiler tarihsel kayıt olarak durur.
  isActive      Boolean  @default(true)

  // --- Hizmet bedeli (hak yağ / sıkım bedeli) ---
  defaultServiceType   ServiceType @default(PERCENTAGE)
  defaultServiceAmount Decimal     @default(10) @db.Decimal(10, 3)
  /// PERCENTAGE modelinde matrah. Kod bugüne kadar bunu OIL_OUT olarak
  /// sabit varsayıyordu; artık fabrika seçebiliyor.
  percentageBasis      FeeBasis    @default(OIL_OUT)
  /// Operatörün parti bazında girebileceği aralık. Sınır yokken %100 girmek
  /// müstahsilin payının tamamını siliyordu.
  minServiceAmount     Decimal?    @db.Decimal(10, 3)
  maxServiceAmount     Decimal?    @db.Decimal(10, 3)
  /// Operatör parti bazında hiç değiştiremesin isteyen fabrikalar için.
  allowServiceOverride Boolean     @default(true)

  // --- Emanet (yağı fabrikada bırakma) ---
  escrowEnabled                 Boolean     @default(true)
  /// Yeni partide "emanete bırak" kutusunun varsayılanı.
  escrowDefault                 Boolean     @default(true)
  escrowModel                   EscrowModel @default(FUNGIBLE)
  /// Aylık depolama ücreti (kg başına). null = ücretsiz saklama.
  escrowStorageFeePerKgPerMonth Decimal?    @db.Decimal(10, 4)
  /// Bu süre sonunda emanet yağ için uyarı üretilir. null = süresiz.
  escrowExpiryDays              Int?
  /// Tek seferde çekilebilecek en az miktar. null = sınır yok.
  minWithdrawalKg               Decimal?    @db.Decimal(12, 3)

  // --- Ödeme / tahsilat ---
  /// false ise borçtan fazla tahsilat reddedilir (avans kabul etmeyen fabrika).
  allowNegativeBalance   Boolean     @default(true)
  liquidationPriceSource PriceSource @default(PER_TRANSACTION)

  // --- Mesaj otomasyonu (SMS) ---
  /// Pro özelliği. false (ücretsiz/demo): üretim sonrası müşteriye SMS
  /// SİMÜLE edilir — operatörün ekranında "gönderildi" görünür ama gerçek SMS
  /// gitmez ve denetim kaydı bunu "simulated" olarak işaretler. true (Pro):
  /// gerçek SMS sağlayıcısı devreye girer (sağlayıcı entegrasyonu ayrıca eklenir).
  messageAutomationEnabled Boolean @default(false)

  // --- Birim ve yuvarlama ---
  /// Çok ülkeli kurulum: TRY / EUR. "TL" arayüzde sabit yazılıydı.
  currency        String  @default("TRY")
  kgDecimalPlaces Int     @default(3)
  tlDecimalPlaces Int     @default(2)
  /// Randıman gösterimi: "1/X" (Türkiye'de yaygın) veya yüzde.
  yieldAsRatio    Boolean @default(true)

  createdAt DateTime @default(now())
  createdBy String? // Değişikliği yapan kullanıcı

  tenant  Tenant            @relation(fields: [tenantId], references: [id])
  batches ProductionBatch[]

  @@unique([tenantId, version])
  @@index([tenantId, isActive])
}

/// Fabrikanın o güne ait yağ alım fiyatı.
///
/// TenantPolicy.liquidationPriceSource = DAILY_TABLE seçildiğinde bozdurma
/// bu tablodan fiyatlanır. PER_TRANSACTION modelinde operatör her işlemde
/// fiyatı kendi yazar — bu, fiyatın tutarlılığını tamamen operatöre bırakır ve
/// aynı gün iki müstahsile farklı kur uygulanabilir. Fabrikaların bir kısmı
/// bunu istemez.
model DailyOilPrice {
  id         String   @id @default(cuid())
  tenantId   String
  /// Fiyatın geçerli olduğu gün (saat bileşeni yok).
  date       DateTime @db.Date
  pricePerKg Decimal  @db.Decimal(12, 4)
  createdAt  DateTime @default(now())
  createdBy  String?

  tenant Tenant @relation(fields: [tenantId], references: [id])

  /// Gün başına tek fiyat: iki kayıt hangisinin geçerli olduğunu belirsiz bırakırdı.
  @@unique([tenantId, date])
}

/// Fabrikanın kendi bidon tipleri.
///
/// Tenant.defaultDrumWeight tek bir Float'tı ve hiçbir iş mantığı onu
/// okumuyordu — yalnızca formda ön değer olarak görünüyordu (üstelik iki
/// ekranda farklı varsayılanla: 50 ve 60). Fabrikalar farklı boyut ve
/// malzemede bidon kullanıyor; her biri ayrı bir kayıt olmalı.
model DrumSize {
  id         String   @id @default(cuid())
  tenantId   String
  name       String // "50'lik teneke", "Küçük bidon"
  capacityKg Decimal  @db.Decimal(8, 3)
  /// Boş bidonun kendi ağırlığı: doluyken tartılan bidondan düşülür.
  tareKg     Decimal  @default(0) @db.Decimal(8, 3)
  type       DrumType
  isActive   Boolean  @default(true)
  isDefault  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
  drums  Drum[]

  @@unique([name, tenantId])
}

model ProductionBatch {
  id           String           @id @default(cuid())
  publicId     String? // Hibrit ID: 26-0001-A7Z
  totalOliveKg Int
  totalOilKg   Decimal          @db.Decimal(12, 3)
  acidRatio    Decimal?         @db.Decimal(5, 2) // Asit oranı
  yieldRatio   Decimal          @db.Decimal(8, 3) // Randıman 1/X
  status       ProductionStatus @default(COMPLETED)

  // Financial / Service Data
  serviceType   ServiceType @default(PERCENTAGE)
  serviceAmount Decimal     @default(0) @db.Decimal(10, 3) // %10 veya 2.5 TL
  totalPrice    Decimal     @default(0) @db.Decimal(14, 2) // Nakit ise toplam tutar

  // Process Data
  processTemp Int? // Sıkım Sıcaklığı
  lineId      Int? // Hat No
  filtration  Boolean @default(false)

  // Müşterinin payı emanete mi bırakıldı, yoksa üretim sonunda bidonla hemen
  // teslim mi edildi?
  //
  // Bu bilgi daha önce yalnızca istek gövdesinde (storeCustomerOil) vardı ve
  // hiçbir yere yazılmıyordu. Sonuç: deliverDrums, yağın zaten teslim edilmiş
  // olduğunu anlayamıyor ve bakiyeden İKİNCİ kez düşüyordu. Emanet, yağın
  // fabrikada beklediği anlamına geldiği için bu bir muhasebe gerçeğidir ve
  // partiyle birlikte saklanmalıdır.
  storedInEscrow Boolean @default(false)

  factoryShareKg  Decimal @db.Decimal(12, 3)
  customerShareKg Decimal @db.Decimal(12, 3)

  /// Bu parti hesaplanırken yürürlükte olan politika sürümü.
  ///
  /// Partinin "hangi kurallara göre" hesaplandığını dondurur. Fabrika oranını
  /// sonradan değiştirse bile bu parti kendi sürümüne bağlı kalır; makbuz
  /// yeniden üretildiğinde aynı sayılar çıkar.
  policyId String?

  tankId       String? // Hangi tanka aktarıldı
  tenantId     String?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  tickets      WeighingTicket[]
  transactions Transaction[] // Bu üretimden kaynaklı işlemler
  drums        Drum[]           @relation("BatchDrums")

  tenant Tenant?       @relation(fields: [tenantId], references: [id])
  tank   StockTank?    @relation(fields: [tankId], references: [id])
  policy TenantPolicy? @relation(fields: [policyId], references: [id])

  @@unique([publicId, tenantId])
}

enum OilType {
  ACID_03
  ACID_05
  ACID_08
  VIRGIN
  LAMPANTE
}

model StockTank {
  id           String            @id @default(cuid())
  name         String
  capacity     Int
  currentLevel Decimal           @default(0) @db.Decimal(12, 3)
  type         OilType           @default(ACID_05)
  acidRatio    Decimal?          @db.Decimal(5, 2) // İçindeki yağın asit oranı (opsiyonel)
  tenantId     String?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  batches      ProductionBatch[]
  transactions Transaction[]

  tenant Tenant? @relation(fields: [tenantId], references: [id])

  @@unique([name, tenantId]) // Tank ismi fabrika bazında unique
}

model Drum {
  id              String     @id @default(cuid())
  code            String
  type            DrumType
  capacity        Decimal    @db.Decimal(8, 3)
  status          DrumStatus @default(AVAILABLE)
  /// Fabrikanın bidon kataloğundaki tip. Katalog Faz 3'te eklendi; eski
  /// bidonlarda null olabilir, o yüzden capacity/type alanları korunuyor.
  drumSizeId      String?
  tenantId        String
  currentHolderId String?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  tenant        Tenant            @relation(fields: [tenantId], references: [id])
  drumSize      DrumSize?         @relation(fields: [drumSizeId], references: [id])
  currentHolder Customer?         @relation("DrumHolder", fields: [currentHolderId], references: [id])
  productions   ProductionBatch[] @relation("BatchDrums")

  @@unique([code, tenantId])
}

enum TransactionType {
  OIL_IN // Üretimden gelen
  OIL_OUT // Yağ teslimatı
  LIQUIDATION // Yağ bozdurma
  PAYMENT // Ödeme alma
  SERVICE_FEE // Hizmet bedeli (Para olarak borç)
}

model Transaction {
  id          String          @id @default(cuid())
  customerId  String
  type        TransactionType
  amountKg    Decimal?        @db.Decimal(12, 3) // Yağ hareketi ise miktar
  amountTL    Decimal?        @db.Decimal(14, 2) // Para hareketi ise tutar
  // Birim fiyat 4 haneli: kg başına kuruş altı fiyatlar toplamda yuvarlama
  // farkı yaratmasın.
  unitPrice   Decimal?        @db.Decimal(12, 4) // Bozdurma birim fiyatı
  tankId      String? // Eğer fiziksel stoktan düşülecekse
  batchId     String? // Hangi üretimden kaynaklandığı
  description String?
  tenantId    String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  tenant   Tenant?          @relation(fields: [tenantId], references: [id])
  customer Customer         @relation(fields: [customerId], references: [id])
  tank     StockTank?       @relation(fields: [tankId], references: [id])
  batch    ProductionBatch? @relation(fields: [batchId], references: [id])
}
